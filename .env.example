# Hyperliquid Copy Trader Configuration
# 複製此檔案為 .env 並填入你的設定

# === 目標交易員 ===
TARGET_TRADER_ADDRESS=0xf97ad6704baec104d00b88e0c157e2b7b3a1ddd1

# === 你的帳戶 ===
# 用來「簽名下單」的私鑰。建議在 Hyperliquid → More → API 建立 agent(API 錢包)
# 取得其私鑰填於此；也可直接用主錢包私鑰。0x 前綴有無皆可。
WALLET_PRIVATE_KEY=your_agent_or_wallet_private_key_here

# ⚠️ 重要：這裡填「主帳戶地址」= 實際持有 USDC 的那個地址。
# 不要填 agent / API 錢包地址！agent 只負責簽名，資金與部位都在主帳戶。
# 若你上面用的是主錢包私鑰，這裡就填它對應的地址(兩者相同)。
WALLET_ADDRESS=your_main_account_address_here

# === 資金控管 ===
# 你分配給跟單的資金 (USDC)，例如 5000。
# 設 <= 0（如 0 或 -1）= 自動：用帳戶當前權益（含 spot 的 unified 淨值，有多少用多少）。
ALLOCATED_CAPITAL=5000

# 資金使用率 (0~1)：下單只用上面資金的這個比例去縮放 (1 = 不保留緩衝)。
# 預設 1.0 不調整；若要留保證金緩衝可調低 (如 0.7)。
CAPITAL_UTILIZATION=1.0

# 倉位權重 (0~1)：靜態手動權重，乘在每個跟單大小上。預設 1 不縮。
# 最終權重 = POSITION_WEIGHT × 波動權重(若啟用)。
POSITION_WEIGHT=1.0

# 波動權重：對目標單日盈虧絕對值算 14 天 Z-Score，市場妖度高時自動去槓桿。
# 權重 = 1 - clip(Z×0.2, 0, 0.7)。預設啟用。
VOLATILITY_WEIGHT_ENABLED=true

# 抗單保護：對目標持倉時間算 Z-Score，偵測硬撐抗單；異常時拒絕複製其補倉。預設關閉。
HOLDING_PROTECTION_ENABLED=false

# 持倉時間 Z-Score 超過此值即視為抗單 (預設 2.0)。
HOLDING_PROTECTION_Z=2.0

# 最大虧損比例，達到此比例自動停止跟單 (0.0 ~ 1.0)
MAX_DRAWDOWN_PCT=0.20

# === 交易設定 ===
# 是否啟用真實下單 (false = 只監控不下單，用於測試)
LIVE_TRADING=false

# 每小時在第幾分鐘檢查並鏡像目標掛單 (0~59，預設 55，提早 5 分鐘掛單)
CHECK_MINUTE=55

# 美股「非活躍時段」的同步頻率 (活躍時段一律每分鐘，不受此影響)：
#   hourly (預設) = 每小時第 CHECK_MINUTE 分同步一次
#   5min          = 每 5 分鐘同步一次
OFFHOURS_SYNC_MODE=hourly

# 是否跟單 xyz DEX (美股永續)。false = 只做 crypto，不查詢/不下單美股標的。
ENABLE_XYZ=false

# 跟單比例分母(目標本金)是否含目標的 spot USDC。
# false (預設) = 只看目標 perp 權益，比例反映目標真實 perp 槓桿(倉位較大)。
# true = 含目標 spot(目標停大筆 USDC 在 spot 時我方倉位會偏小)。
# 只影響目標分母；我方帳戶權益(回撤用)一律含 spot。
TARGET_EQUITY_INCLUDE_SPOT=false

# 最小下單名目值 (USDC)。Hyperliquid 硬性下限為 $10，建議維持 10。
# 換算後低於此值的掛單會被跳過並發 Telegram 提醒（代表資金分散到過多標的）。
MIN_ORDER_NOTIONAL=10

# size 容忍度 (0~1，預設 0.02=2%)：掛單/部位與目標大小差距 <= 此比例就不動，
# 避免本金或權益微幅波動造成無謂洗單。調高=更穩(少動)，調低=更貼目標(較常微調)。
SIZE_TOLERANCE=0.02

# 進場掛單的名目槓桿 (cross)。"max"=用標的最大槓桿(最省保證金)；或填數字如 20。
# 掛單佔用保證金=名目/槓桿，1x 會佔滿全額導致保證金不足；倉位大小由跟單比例決定、與此無關。
ORDER_LEVERAGE=max

# === Telegram 通知 ===
# 1. 向 @BotFather 建立 bot，取得 token
# 2. 向 @userinfobot 取得你的 chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 通知開關。系統/警告/同步摘要/平倉一律發送；以下可自行開關：
NOTIFY_ORDERS=false        # 掛單/改單明細（量大，預設關）
NOTIFY_OPENS=false         # 開倉明細（預設關）
NOTIFY_VOLATILITY=true     # 我的帳戶波動權重（每小時一則）

# 目標有效槓桿上限保護 (0=不啟用)：目標瀕臨清算時有效槓桿會暴衝，
# 設此值(如 10)後，目標有效槓桿超過時自動把我方倉位縮回此上限，避免被一起拖下水。
MAX_TARGET_LEVERAGE=0

# === 網路 ===
# mainnet 或 testnet
NETWORK=mainnet
