# Hyperliquid Copy Trader Configuration
# 複製此檔案為 .env 並填入你的設定

# === 目標交易員 ===
TARGET_TRADER_ADDRESS=0xf97ad6704baec104d00b88e0c157e2b7b3a1ddd1

# === 你的帳戶 ===
# 你的 Hyperliquid 錢包私鑰 (不含 0x 前綴)
WALLET_PRIVATE_KEY=your_private_key_here

# 你的錢包地址 (或 agent wallet 地址)
WALLET_ADDRESS=your_wallet_address_here

# === 資金控管 ===
# 你分配給跟單的資金 (USDC)，例如 5000
ALLOCATED_CAPITAL=5000

# 最大虧損比例，達到此比例自動停止跟單 (0.0 ~ 1.0)
MAX_DRAWDOWN_PCT=0.20

# === 交易設定 ===
# 是否啟用真實下單 (false = 只監控不下單，用於測試)
LIVE_TRADING=false

# 輪詢間隔秒數 (建議 5~10)
POLL_INTERVAL_SECONDS=5

# 最小下單金額 (低於此不跟單，避免手續費侵蝕)
MIN_ORDER_NOTIONAL=10

# === 網路 ===
# mainnet 或 testnet
NETWORK=mainnet
